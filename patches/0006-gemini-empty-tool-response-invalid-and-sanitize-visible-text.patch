+    @classmethod
+    def _sanitize_visible_text(cls, text: Optional[str]) -> Optional[str]:
+        if text is None:
+            return None
+        sanitized = cls._LEADING_CTRL_TOKEN_PATTERN.sub("", text)
+        sanitized = cls._CONTROL_CHAR_PATTERN.sub("", sanitized)
+        return sanitized
+
+    @staticmethod
+    def _has_tool_calling_intent(optional_params: Optional[dict]) -> bool:
+        if not isinstance(optional_params, dict):
+            return False
+        if optional_params.get("tools"):
+            return True
+        if optional_params.get("functions"):
+            return True
+        return False
+
+    @classmethod
+    def _message_has_visible_output(
+        cls, message: Optional[ChatCompletionResponseMessage]
+    ) -> bool:
+        if not message:
+            return False
+        content = cls._sanitize_visible_text(message.get("content"))
+        if content is not None and content.strip():
+            return True
+        if message.get("tool_calls") or message.get("function_call"):
+            return True
+        if message.get("audio") or message.get("images"):
+            return True
+        return False
+
+    @classmethod
+    def _raise_on_invalid_empty_tool_response(
+        cls,
