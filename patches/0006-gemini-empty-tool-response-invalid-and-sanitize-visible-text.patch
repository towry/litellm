+            finish_message_summary = " | ".join(native_finish_messages) or "None"
+            raise VertexAIError(
+                status_code=503,
+                message=(
+                    "LITELLM_GEMINI_EMPTY_TOOL_RESPONSE_RETRYABLE: "
