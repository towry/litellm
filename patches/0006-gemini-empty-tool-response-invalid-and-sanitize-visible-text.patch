+            for candidate in candidates
+            if candidate.get("finishMessage")
+        ]
+
+        if native_finish_reasons and all(
+            reason in cls._INVALID_EMPTY_TOOL_FINISH_REASONS
+            for reason in native_finish_reasons
+        ):
