+def drop_none_schema_enum_values(
+    schema: Union[Dict[str, Any], List[Any], Any],
+    depth: int = 0,
+    max_depth: int = DEFAULT_MAX_RECURSE_DEPTH,
+) -> Union[Dict[str, Any], List[Any], Any]:
+    if depth >= max_depth:
+        return schema
+
+    if isinstance(schema, list):
+        return [drop_none_schema_enum_values(item, depth + 1, max_depth) for item in schema]
+
+    if isinstance(schema, dict):
+        normalized_schema: Dict[str, Any] = {}
+        for key, value in schema.items():
+            if key == "enum" and value is None:
+                continue
+            if key == "enum" and isinstance(value, list):
+                enum_values = [item for item in value if item is not None]
+                if enum_values:
+                    normalized_schema[key] = enum_values
+                continue
+            if isinstance(value, (dict, list)):
+                normalized_schema[key] = drop_none_schema_enum_values(value, depth + 1, max_depth)
+            else:
+                normalized_schema[key] = value
+        return normalized_schema
+
+    return schema
+
