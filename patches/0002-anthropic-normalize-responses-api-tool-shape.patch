+def test_map_tool_helper_normalizes_responses_api_tool_shape():
+    """
+    Responses API function tools can arrive with top-level
+    name/description/parameters instead of a nested function object.
+    Anthropic mapping should normalize that shape instead of raising
+    KeyError('function').
+    """
+    config = AnthropicConfig()
+
+    tool = {
+        "type": "function",
+        "name": "get_weather",
+        "description": "Get weather",
+        "parameters": {
+            "type": "object",
+            "properties": {
+                "city": {"type": "string"},
+            },
+            "required": ["city"],
+        },
+        "strict": True,
+    }
+
+    result, _ = config._map_tool_helper(tool)
+    assert result is not None
+    assert result["name"] == "get_weather"
+    assert result["description"] == "Get weather"
+    assert result["input_schema"]["type"] == "object"
+    assert "city" in result["input_schema"]["properties"]
+    assert "function" not in tool, "_map_tool_helper should not mutate caller data"
+
+
