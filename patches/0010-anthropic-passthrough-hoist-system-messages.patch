+    @staticmethod
+    def _hoist_system_messages_to_top_level(messages: List[Dict], optional_params: Dict) -> List[Dict]:
+        """Move system-role messages into the Anthropic Messages top-level system parameter."""
+        system_messages = [
+            message for message in messages if isinstance(message, dict) and message.get("role") == "system"
+        ]
+        if not system_messages:
+            return messages
+
+        def _as_blocks(content: object) -> List[Dict]:
+            if isinstance(content, str):
+                return [{"type": "text", "text": content}] if content else []
+            if isinstance(content, list):
+                return [block for block in content if isinstance(block, dict)]
+            return []
+
+        merged_system = [
+            *_as_blocks(optional_params.get("system")),
+            *(block for message in system_messages for block in _as_blocks(message.get("content"))),
+        ]
+        if merged_system:
+            optional_params["system"] = merged_system
+
+        return [
+            message for message in messages if not (isinstance(message, dict) and message.get("role") == "system")
+        ]
+
